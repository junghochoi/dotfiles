[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = Daniel Choi 
  email = dchoi315@gmail.com
[alias]
	co = !git checkout $(git branch | fzf)
	st = status
  d = !git branch -d $(git branch | fzf)
  br = branch
  
[push]
	autoSetupRemote = true
