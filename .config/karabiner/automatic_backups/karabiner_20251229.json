{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Launch Notion",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "n",
                                    "modifiers": { "mandatory": ["command, control, option, shift"] }
                                },
                                "to": [
                                  {"shell_command": "open -a 'notion'"}             
                                ],
                                "type": "basic"
                            }
                        ],
                        "enabled": "false" 
                    },
                    {
                        "description": "Change semicolon to hyper key if pressed with other keys, semicolon if pressed alone.",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "semicolon",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_control", "left_command", "left_option"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "semicolon" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Change caps_lock to left_control if pressed with other keys, change caps_lock to escape if pressed alone.",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control" }],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
